<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="28dp"
    android:paddingEnd="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:gravity="center_vertical"
    android:minHeight="52dp"
    android:background="?attr/selectableItemBackground">

    <!-- Left accent line -->
    <View
        android:layout_width="2dp"
        android:layout_height="28dp"
        android:layout_marginEnd="12dp"
        android:background="@color/divider_color"/>

    <!-- Name, subtitle & P&L column -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_asset_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:fontFamily="@font/geist_mono_semi_bold"
            android:textStyle="bold"
            tools:text="RELIANCE.NS"/>

        <TextView
            android:id="@+id/tv_asset_notes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:textColor="@color/text_tertiary"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone"
            tools:text="2 units · ₹1,200/unit"/>

        <!-- P&L line — shown only when buyPrice is set -->
        <TextView
            android:id="@+id/tv_asset_pl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="11sp"
            android:fontFamily="@font/geist_mono"
            android:visibility="gone"
            tools:text="▲ ₹3,200 (+2.74%)"/>
    </LinearLayout>

    <!-- Right column: value + P&L amount -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end"
        android:layout_marginEnd="8dp">

        <TextView
            android:id="@+id/tv_asset_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:fontFamily="@font/geist_mono_regular"
            tools:text="₹1,20,000"/>

        <!-- Invested amount — shown only when buyPrice is set -->
        <TextView
            android:id="@+id/tv_asset_invested"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:textSize="10sp"
            android:textColor="@color/text_tertiary"
            android:fontFamily="@font/geist_mono"
            android:visibility="gone"
            tools:text="inv ₹1,16,800"/>
    </LinearLayout>

    <!-- Delete button -->
    <ImageButton
        android:id="@+id/btn_delete_asset"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_close"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:alpha="0.35"
        android:contentDescription="Delete asset"/>

</LinearLayout>
