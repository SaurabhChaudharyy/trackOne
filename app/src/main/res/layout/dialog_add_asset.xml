<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- ── FETCHABLE mode (stocks / gold / crypto) ── -->

    <!-- Step 1: Symbol search field — user types to filter symbols -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_symbol"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Search symbol"
        app:boxStrokeColor="@color/border_color"
        app:hintTextColor="@color/text_tertiary"
        app:startIconDrawable="@drawable/ic_search"
        app:startIconTint="@color/text_tertiary"
        android:visibility="gone">

        <AutoCompleteTextView
            android:id="@+id/et_symbol"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/geist_mono"
            android:completionThreshold="1"
            android:dropDownHeight="200dp"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Step 2: Price card — appears after a symbol is selected and price is fetched -->
    <LinearLayout
        android:id="@+id/ll_price_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical"
        android:background="@drawable/bg_price_card"
        android:padding="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_price_card_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Current Price"
            android:textColor="@color/text_tertiary"
            android:textSize="11sp"
            android:letterSpacing="0.05"
            android:fontFamily="@font/geist_mono"/>

        <!-- Loading indicator shown while fetching -->
        <LinearLayout
            android:id="@+id/ll_price_loading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <ProgressBar
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:indeterminate="true"
                style="?android:attr/progressBarStyleSmall"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fetching price…"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/geist_mono"/>
        </LinearLayout>

        <!-- Price shown on success -->
        <TextView
            android:id="@+id/tv_fetch_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text=""
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:fontFamily="@font/geist_mono_bold"
            android:textStyle="bold"
            android:visibility="gone"/>

        <!-- Error message on failure -->
        <TextView
            android:id="@+id/tv_price_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text=""
            android:textColor="@color/loss_red"
            android:textSize="12sp"
            android:fontFamily="@font/geist_mono"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Step 3: Quantity (shown after price fetch success) -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_quantity"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Quantity / Units"
        app:boxStrokeColor="@color/border_color"
        app:hintTextColor="@color/text_tertiary"
        android:visibility="gone">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_quantity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/geist_mono"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Step 3b: Buy price per unit (optional — for P&L tracking) -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_buy_price"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Avg Buy Price (₹) — optional"
        app:boxStrokeColor="@color/border_color"
        app:hintTextColor="@color/text_tertiary"
        android:visibility="gone">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_buy_price"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/geist_mono"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Step 4: Computed total value (read-only once auto-calculated; editable as fallback) -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_value"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Current Value (₹)"
        app:boxStrokeColor="@color/border_color"
        app:hintTextColor="@color/text_tertiary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/geist_mono"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- ── MANUAL mode (MF, cash, bank) ── -->

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_name"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Label / Account name"
        app:boxStrokeColor="@color/border_color"
        app:hintTextColor="@color/text_tertiary"
        android:visibility="gone">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/geist_mono"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Stub views to keep old binding references alive (always gone) -->
    <LinearLayout
        android:id="@+id/ll_fetch_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_fetch_price"
            style="@style/Widget.App.Button.Tonal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fetch Price"
            android:textSize="12sp"/>
    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_notes"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Label / Note (e.g. Physical, Digital, Jewellery)"
        app:boxStrokeColor="@color/border_color"
        app:hintTextColor="@color/text_tertiary"
        android:visibility="gone">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_notes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/geist_mono"/>
    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>
