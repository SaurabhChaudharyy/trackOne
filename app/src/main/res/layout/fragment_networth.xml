                    android:layout_height="wrap_content"
                    android:text="₹0"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp"
                    android:layout_marginEnd="8dp"/>

                <ImageButton
                    android:id="@+id/btn_add_cash"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_add"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Add cash"
                    android:tint="@color/text_tertiary"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_cash"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:visibility="visible"
                tools:listitem="@layout/item_networth_asset"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_color"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/section_bank"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/header_bank"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_label_bank"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bank Balance"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:fontFamily="@font/inter_semi_bold"/>

                    <TextView
                        android:id="@+id/tv_count_bank"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp"
                        android:background="@drawable/bg_count_pill"
                        android:textColor="@color/text_primary"
                        android:textSize="10sp"
                        android:fontFamily="@font/inter_semi_bold"
                        android:visibility="gone"
                        tools:text="3"
                        tools:visibility="visible"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_view_all_bank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View all"
                    android:textColor="@color/text_tertiary"
                    android:textSize="11sp"
                    android:fontFamily="@font/inter"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:background="@drawable/bg_view_all"
                    android:layout_marginEnd="6dp"
                    android:visibility="gone"
                    tools:visibility="visible"/>

                <TextView
                    android:id="@+id/tv_total_bank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp"
                    android:layout_marginEnd="8dp"/>

                <ImageButton
                    android:id="@+id/btn_add_bank"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_add"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Add bank balance"
                    android:tint="@color/text_tertiary"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_bank"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:visibility="visible"
                tools:listitem="@layout/item_networth_asset"/>
        </LinearLayout>

    </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Bulk-selection action bar: slides in from bottom when long-pressing any asset row -->
    <LinearLayout
        android:id="@+id/ll_selection_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@color/background"
        android:elevation="12dp"
        android:visibility="gone"
        tools:visibility="visible">

        <!-- Cancel / exit selection mode -->
        <TextView
            android:id="@+id/tv_selection_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:fontFamily="@font/inter"
            android:paddingEnd="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"/>

        <!-- Selected count label -->
        <TextView
            android:id="@+id/tv_selection_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:fontFamily="@font/inter_semi_bold"
            tools:text="3 selected"/>

        <!-- Select All / Deselect All toggle -->
        <TextView
            android:id="@+id/tv_select_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select All"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:fontFamily="@font/inter"
            android:paddingEnd="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"/>

        <!-- Delete selected -->
        <ImageButton
            android:id="@+id/btn_delete_selected"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_delete"
            app:tint="@color/loss_red"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Delete selected"/>

    </LinearLayout>

</FrameLayout>
