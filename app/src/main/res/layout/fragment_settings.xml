<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/tv_settings_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:fontFamily="@font/geist_mono_bold"
            android:letterSpacing="0.02"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tv_settings_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manage your data and preferences"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            android:fontFamily="@font/geist_mono"
            android:layout_marginBottom="28dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WATCHLIST"
            android:textColor="@color/text_tertiary"
            android:textSize="10sp"
            android:fontFamily="@font/geist_mono_semi_bold"
            android:letterSpacing="0.12"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:id="@+id/card_export_watchlist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_settings_card"
            android:padding="16dp"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_settings_icon"
                    android:gravity="center"
                    android:layout_marginEnd="14dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_export"
                        android:tint="@color/text_primary"
                        tools:ignore="ContentDescription"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Export Watchlist"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:fontFamily="@font/geist_mono_semi_bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Save your watchlist symbols to a JSON file"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp"
                        android:fontFamily="@font/geist_mono"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/text_tertiary"
                    tools:ignore="ContentDescription"/>
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/card_import_watchlist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_settings_card"
            android:padding="16dp"
            android:layout_marginBottom="24dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_settings_icon"
                    android:gravity="center"
                    android:layout_marginEnd="14dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_import"
                        android:tint="@color/text_primary"
                        tools:ignore="ContentDescription"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Import Watchlist"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:fontFamily="@font/geist_mono_semi_bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Restore watchlist from a backup file"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp"
                        android:fontFamily="@font/geist_mono"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/text_tertiary"
                    tools:ignore="ContentDescription"/>
            </LinearLayout>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STOCKS &amp; INVESTMENTS"
            android:textColor="@color/text_tertiary"
            android:textSize="10sp"
            android:fontFamily="@font/geist_mono_semi_bold"
            android:letterSpacing="0.12"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:id="@+id/card_export_assets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_settings_card"
            android:padding="16dp"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_settings_icon"
                    android:gravity="center"
                    android:layout_marginEnd="14dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_export"
                        android:tint="@color/text_primary"
                        tools:ignore="ContentDescription"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Export Stocks &amp; Investments"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:fontFamily="@font/geist_mono_semi_bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Save your net worth assets to a JSON file"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp"
                        android:fontFamily="@font/geist_mono"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/text_tertiary"
                    tools:ignore="ContentDescription"/>
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/card_import_assets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_settings_card"
            android:padding="16dp"
            android:layout_marginBottom="24dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_settings_icon"
                    android:gravity="center"
                    android:layout_marginEnd="14dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_import"
                        android:tint="@color/text_primary"
                        tools:ignore="ContentDescription"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Import Stocks &amp; Investments"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:fontFamily="@font/geist_mono_semi_bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Restore net worth assets from a backup file"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp"
                        android:fontFamily="@font/geist_mono"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/text_tertiary"
                    tools:ignore="ContentDescription"/>
            </LinearLayout>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ABOUT"
            android:textColor="@color/text_tertiary"
            android:textSize="10sp"
            android:fontFamily="@font/geist_mono_semi_bold"
            android:letterSpacing="0.12"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_settings_card"
            android:padding="16dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_settings_icon"
                android:gravity="center"
                android:layout_marginEnd="14dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_info"
                    android:tint="@color/text_primary"
                    tools:ignore="ContentDescription"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="trackOne"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:fontFamily="@font/geist_mono_semi_bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="v1.0 · Data stored locally on device"
                    android:textColor="@color/text_tertiary"
                    android:textSize="11sp"
                    android:fontFamily="@font/geist_mono"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_loading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="32dp"
            android:visibility="gone">

            <ProgressBar
                android:id="@+id/progress_backup"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:indeterminateTint="@color/text_secondary"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:id="@+id/tv_loading_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Working…"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="@font/geist_mono"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
