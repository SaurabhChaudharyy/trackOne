<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_item_root"
    android:layout_width="match_parent"
    android:layout_height="46dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingLeft="8dp"
    android:paddingRight="8dp"
    android:paddingTop="2dp"
    android:paddingBottom="2dp">

    <!-- Symbol & Name -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.5"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_item_symbol"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NVDA"
            android:textColor="#FAFAFA"
            android:textSize="13sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:fontFamily="@font/geist_mono_semi_bold"/>

        <TextView
            android:id="@+id/widget_item_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NVIDIA Corp"
            android:textColor="#52525B"
            android:textSize="10sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:fontFamily="@font/geist_mono_regular"/>
    </LinearLayout>

    <!-- Price -->
    <TextView
        android:id="@+id/widget_item_price"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="$187.62"
        android:textColor="#FAFAFA"
        android:textSize="12sp"
        android:gravity="end"
        android:singleLine="true"
        android:fontFamily="@font/geist_mono_regular"/>

    <!-- Change % -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="end|center_vertical"
        android:layout_marginLeft="4dp">

        <TextView
            android:id="@+id/widget_item_change"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-7.94"
            android:textColor="#EF4444"
            android:textSize="11sp"
            android:singleLine="true"
            android:visibility="gone"
            android:fontFamily="@font/geist_mono_regular"/>

        <TextView
            android:id="@+id/widget_item_change_percent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-4.06%"
            android:textColor="#EF4444"
            android:textSize="12sp"
            android:singleLine="true"
            android:fontFamily="@font/geist_mono_regular"/>

        <ImageView
            android:id="@+id/widget_item_indicator"
            android:layout_width="11dp"
            android:layout_height="11dp"
            android:layout_marginLeft="2dp"
            android:src="@drawable/ic_arrow_down"
            android:contentDescription="Trend"/>
    </LinearLayout>

</LinearLayout>
