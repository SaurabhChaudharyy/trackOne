<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_item_root"
    android:layout_width="match_parent"
    android:layout_height="46dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingLeft="8dp"
    android:paddingRight="8dp">

    <!-- Left column: symbol + company name -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.5"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_item_symbol"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NVDA"
            android:textColor="#09090B"
            android:textSize="13sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:fontFamily="@font/inter_semi_bold"/>

        <TextView
            android:id="@+id/widget_item_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:text="NVIDIA Corp"
            android:textColor="#A1A1AA"
            android:textSize="10sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:fontFamily="@font/inter"/>
    </LinearLayout>

    <!-- Middle column: price -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="end|center_vertical">

        <TextView
            android:id="@+id/widget_item_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$187.62"
            android:textColor="#09090B"
            android:textSize="12sp"
            android:singleLine="true"
            android:fontFamily="@font/geist_mono_regular"/>
    </LinearLayout>

    <!-- Right column: change pill -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="end|center_vertical"
        android:orientation="horizontal">

        <!-- Gain pill: neon yellow bg, black text -->
        <!-- Gain pill: neon yellow bg, black text -->
        <TextView
            android:id="@+id/widget_item_gain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="64dp"
            android:gravity="center"
            android:text="+2.65%"
            android:textColor="#09090B"
            android:textSize="12sp"
            android:singleLine="true"
            android:fontFamily="@font/geist_mono_regular"
            android:background="@drawable/bg_gain_pill"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:visibility="gone"/>

        <!-- Loss pill: red bg, black text -->
        <TextView
            android:id="@+id/widget_item_loss"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="64dp"
            android:gravity="center"
            android:text="-4.06%"
            android:textColor="#09090B"
            android:textSize="12sp"
            android:singleLine="true"
            android:fontFamily="@font/geist_mono_regular"
            android:background="@drawable/bg_loss_pill"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:visibility="gone"/>

    </LinearLayout>

</LinearLayout>
