<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh_home"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="40dp">

            <!-- ── HERO PORTFOLIO ─────────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/card_portfolio_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="20dp"
                android:clickable="true"
                android:focusable="true"
                android:descendantFocusability="blocksDescendants"
                android:foreground="?attr/selectableItemBackground"
                android:visibility="gone">

                <!-- Portfolio Value label (left) + Date (right) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Portfolio Value"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:letterSpacing="0.04"/>

                    <TextView
                        android:id="@+id/tv_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp"
                        android:fontFamily="@font/geist_mono"
                        android:letterSpacing="0.04"
                        tools:text="TUE, 28 APR 2026"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_portfolio_current"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/text_primary"
                    android:textSize="40sp"
                    android:fontFamily="@font/inter_semi_bold"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02"
                    android:singleLine="true"
                    tools:text="₹12,34,567"/>

                <!-- P&L chip + spacer + Invested (right) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:id="@+id/tv_portfolio_pnl"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="5dp"
                        android:textSize="12sp"
                        android:fontFamily="@font/geist_mono"
                        android:textStyle="bold"
                        android:background="@drawable/bg_pnl_chip"
                        android:visibility="gone"
                        tools:text="↗ +₹14,200  (+5.9%)"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"/>

                    <LinearLayout
                        android:id="@+id/ll_invested_row"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Invested "
                            android:textColor="@color/text_tertiary"
                            android:textSize="11sp"
                            android:fontFamily="@font/inter"/>

                        <TextView
                            android:id="@+id/tv_invested_amount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:fontFamily="@font/geist_mono"
                            tools:text="₹11,62,092"/>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_current_amount_inline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    tools:text="placeholder"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="TAP FOR FULL BREAKDOWN  →"
                    android:textColor="@color/text_tertiary"
                    android:textSize="9sp"
                    android:fontFamily="@font/inter_semi_bold"
                    android:letterSpacing="0.08"
                    android:textAllCaps="true"/>
            </LinearLayout>

            <!-- ── PORTFOLIO CHART ────────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/ll_portfolio_chart_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Chart -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp">

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/portfolio_line_chart"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>

                    <ProgressBar
                        android:id="@+id/portfolio_chart_progress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:visibility="gone"/>
                </FrameLayout>
            </LinearLayout>

            <!-- ── DIVIDER ───────────────────────────────────────────────── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_color"/>

            <!-- ── TODAY'S MOVERS ─────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TODAY'S MOVERS"
                    android:textColor="@color/text_tertiary"
                    android:textSize="10sp"
                    android:fontFamily="@font/inter_semi_bold"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    android:paddingHorizontal="20dp"/>

                <!-- Horizontal scroll of mover chips -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginTop="10dp">

                    <LinearLayout
                        android:id="@+id/ll_top_movers_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:visibility="gone"/>
                </HorizontalScrollView>

                <LinearLayout
                    android:id="@+id/top_mover_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_index_card"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp"
                    android:layout_marginHorizontal="20dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Add investments to your portfolio to see today's movers"
                        android:textColor="@color/text_tertiary"
                        android:textSize="12sp"
                        android:fontFamily="@font/inter"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/top_mover_loading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_index_card"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp"
                    android:layout_marginHorizontal="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading market data…"
                        android:textColor="@color/text_tertiary"
                        android:textSize="12sp"
                        android:fontFamily="@font/inter"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ── DIVIDER ───────────────────────────────────────────────── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:background="@color/divider_color"/>

            <!-- ── MARKET STATUS ROW ──────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Markets"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:fontFamily="@font/inter_semi_bold"/>

                <LinearLayout
                    android:id="@+id/chip_india_market"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_market_chip"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NSE  "
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp"
                        android:fontFamily="@font/inter"
                        android:letterSpacing="0.04"/>

                    <TextView
                        android:id="@+id/tv_india_market_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Closed"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp"
                        android:fontFamily="@font/inter_semi_bold"
                        android:textStyle="bold"
                        tools:text="Open"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/chip_us_market"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_market_chip"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NYSE  "
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp"
                        android:fontFamily="@font/inter"
                        android:letterSpacing="0.04"/>

                    <TextView
                        android:id="@+id/tv_us_market_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Closed"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp"
                        android:fontFamily="@font/inter_semi_bold"
                        android:textStyle="bold"
                        tools:text="Closed"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ── INDIA LABEL ────────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:paddingHorizontal="20dp"
                android:text="INDIA"
                android:textColor="@color/text_tertiary"
                android:textSize="10sp"
                android:fontFamily="@font/inter_semi_bold"
                android:letterSpacing="0.12"
                android:textAllCaps="true"/>

            <!-- ── INDIA INDEX CARDS ──────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:paddingHorizontal="20dp">

                <LinearLayout
                    android:id="@+id/card_nifty"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_index_card"
                    android:padding="14dp"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:descendantFocusability="blocksDescendants"
                    android:foreground="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NIFTY 50"
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp"
                        android:fontFamily="@font/inter"
                        android:letterSpacing="0.05"/>

                    <TextView
                        android:id="@+id/tv_nifty_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:fontFamily="@font/geist_mono_bold"
                        android:singleLine="true"
                        tools:text="23,408"/>

                    <LinearLayout
                        android:id="@+id/pill_nifty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:clickable="false"
                        android:focusable="false"
                        android:background="@drawable/bg_loss_pill"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp">

                        <ImageView
                            android:id="@+id/iv_nifty_trend"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_marginEnd="2dp"
                            android:src="@drawable/ic_trending_down"
                            android:contentDescription="trend"/>

                        <TextView
                            android:id="@+id/tv_nifty_change"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/loss_red"
                            android:textSize="11sp"
                            android:fontFamily="@font/geist_mono"
                            tools:text="-0.73%"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/card_sensex"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_index_card"
                    android:padding="14dp"
                    android:layout_marginStart="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:descendantFocusability="blocksDescendants"
                    android:foreground="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SENSEX"
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp"
                        android:fontFamily="@font/inter"
                        android:letterSpacing="0.05"/>

                    <TextView
                        android:id="@+id/tv_sensex_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:fontFamily="@font/geist_mono_bold"
                        android:singleLine="true"
                        tools:text="76,985"/>

                    <LinearLayout
                        android:id="@+id/pill_sensex"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:clickable="false"
                        android:focusable="false"
                        android:background="@drawable/bg_gain_pill"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp">

                        <ImageView
                            android:id="@+id/iv_sensex_trend"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_marginEnd="2dp"
                            android:src="@drawable/ic_trending_up"
                            android:contentDescription="trend"/>

                        <TextView
                            android:id="@+id/tv_sensex_change"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/gain_green"
                            android:textSize="11sp"
                            android:fontFamily="@font/geist_mono"
                            tools:text="+0.42%"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ── US LABEL ───────────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:paddingHorizontal="20dp"
                android:text="UNITED STATES"
                android:textColor="@color/text_tertiary"
                android:textSize="10sp"
                android:fontFamily="@font/inter_semi_bold"
                android:letterSpacing="0.12"
                android:textAllCaps="true"/>

            <!-- ── US INDEX CARDS ─────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:paddingHorizontal="20dp">

                <LinearLayout
                    android:id="@+id/card_sp500"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_index_card"
                    android:padding="14dp"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:descendantFocusability="blocksDescendants"
                    android:foreground="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="S&amp;P 500"
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp"
                        android:fontFamily="@font/inter"
                        android:letterSpacing="0.05"/>

                    <TextView
                        android:id="@+id/tv_sp500_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:fontFamily="@font/geist_mono_bold"
                        android:singleLine="true"
                        tools:text="5,667"/>

                    <LinearLayout
                        android:id="@+id/pill_sp500"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:clickable="false"
                        android:focusable="false"
                        android:background="@drawable/bg_gain_pill"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp">

                        <ImageView
                            android:id="@+id/iv_sp500_trend"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_marginEnd="2dp"
                            android:src="@drawable/ic_trending_up"
                            android:contentDescription="trend"/>

                        <TextView
                            android:id="@+id/tv_sp500_change"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/gain_green"
                            android:textSize="11sp"
                            android:fontFamily="@font/geist_mono"
                            tools:text="+0.22%"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/card_nasdaq"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_index_card"
                    android:padding="14dp"
                    android:layout_marginStart="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:descendantFocusability="blocksDescendants"
                    android:foreground="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NASDAQ"
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp"
                        android:fontFamily="@font/inter"
                        android:letterSpacing="0.05"/>

                    <TextView
                        android:id="@+id/tv_nasdaq_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:fontFamily="@font/geist_mono_bold"
                        android:singleLine="true"
                        tools:text="17,754"/>

                    <LinearLayout
                        android:id="@+id/pill_nasdaq"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:clickable="false"
                        android:focusable="false"
                        android:background="@drawable/bg_loss_pill"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp">

                        <ImageView
                            android:id="@+id/iv_nasdaq_trend"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_marginEnd="2dp"
                            android:src="@drawable/ic_trending_down"
                            android:contentDescription="trend"/>

                        <TextView
                            android:id="@+id/tv_nasdaq_change"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/loss_red"
                            android:textSize="11sp"
                            android:fontFamily="@font/geist_mono"
                            tools:text="-0.18%"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- ── LIVE UPDATE BANNER ─────────────────────────────────────────── -->
    <!-- Shown (with slide-up animation) when fresh live prices are ready. -->
    <LinearLayout
        android:id="@+id/banner_portfolio_updated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/text_primary"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:elevation="8dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/tv_banner_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Portfolio updated — tap to apply"
            android:textColor="@color/background"
            android:textSize="13sp"
            android:fontFamily="@font/inter_semi_bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↑"
            android:textColor="@color/neon_highlight"
            android:textSize="18sp"
            android:fontFamily="@font/inter_semi_bold"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

</FrameLayout>
