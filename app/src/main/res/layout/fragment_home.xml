<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <!-- ── DATE + TIME ─────────────────────────────── -->
        <TextView
            android:id="@+id/tv_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            android:fontFamily="@font/geist_mono"
            android:letterSpacing="0.08"
            android:textAllCaps="true"
            tools:text="WEDNESDAY, 18 MARCH 2026"/>

        <!-- ── GREETING ────────────────────────────────── -->
        <TextView
            android:id="@+id/tv_greeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_primary"
            android:textSize="32sp"
            android:fontFamily="@font/inter_semi_bold"
            android:textStyle="bold"
            android:letterSpacing="-0.03"
            android:lineSpacingMultiplier="1.05"
            tools:text="Good evening."/>

        <!-- ── LIVE TIME ───────────────────────────────── -->
        <TextView
            android:id="@+id/tv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_tertiary"
            android:textSize="14sp"
            android:fontFamily="@font/geist_mono"
            tools:text="10:17 PM IST"/>

        <!-- ── DIVIDER ─────────────────────────────────── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="28dp"
            android:background="@color/divider_color"/>

        <!-- ── MARKET STATUS ROW ───────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Markets"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:fontFamily="@font/inter_semi_bold"
                android:textStyle="bold"/>

            <!-- India status chip -->
            <LinearLayout
                android:id="@+id/chip_india_market"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_market_chip"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:gravity="center_vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NSE  "
                    android:textColor="@color/text_tertiary"
                    android:textSize="10sp"
                    android:fontFamily="@font/inter"
                    android:letterSpacing="0.04"/>

                <TextView
                    android:id="@+id/tv_india_market_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Closed"
                    android:textColor="@color/text_tertiary"
                    android:textSize="11sp"
                    android:fontFamily="@font/inter_semi_bold"
                    android:textStyle="bold"
                    tools:text="Open"/>
            </LinearLayout>

            <!-- US status chip -->
            <LinearLayout
                android:id="@+id/chip_us_market"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_market_chip"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NYSE  "
                    android:textColor="@color/text_tertiary"
                    android:textSize="10sp"
                    android:fontFamily="@font/inter"
                    android:letterSpacing="0.04"/>

                <TextView
                    android:id="@+id/tv_us_market_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Closed"
                    android:textColor="@color/text_tertiary"
                    android:textSize="11sp"
                    android:fontFamily="@font/inter_semi_bold"
                    android:textStyle="bold"
                    tools:text="Closed"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ── SECTION LABEL: INDIA ───────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="INDIA"
            android:textColor="@color/text_tertiary"
            android:textSize="10sp"
            android:fontFamily="@font/inter_semi_bold"
            android:letterSpacing="0.12"
            android:textAllCaps="true"/>

        <!-- ── INDIA INDEX CARDS ─────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <!-- NIFTY 50 -->
            <LinearLayout
                android:id="@+id/card_nifty"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_index_card"
                android:padding="14dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NIFTY 50"
                    android:textColor="@color/text_tertiary"
                    android:textSize="10sp"
                    android:fontFamily="@font/inter"
                    android:letterSpacing="0.05"/>

                <TextView
                    android:id="@+id/tv_nifty_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:fontFamily="@font/geist_mono_bold"
                    android:singleLine="true"
                    tools:text="23,408"/>

                <LinearLayout
                    android:id="@+id/pill_nifty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_loss_pill"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <ImageView
                        android:id="@+id/iv_nifty_trend"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginEnd="2dp"
                        android:src="@drawable/ic_trending_down"
                        android:contentDescription="trend"/>

                    <TextView
                        android:id="@+id/tv_nifty_change"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/loss_red"
                        android:textSize="11sp"
                        android:fontFamily="@font/geist_mono"
                        tools:text="-0.73%"/>
                </LinearLayout>
            </LinearLayout>

            <!-- SENSEX -->
            <LinearLayout
                android:id="@+id/card_sensex"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_index_card"
                android:padding="14dp"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SENSEX"
                    android:textColor="@color/text_tertiary"
                    android:textSize="10sp"
                    android:fontFamily="@font/inter"
                    android:letterSpacing="0.05"/>

                <TextView
                    android:id="@+id/tv_sensex_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:fontFamily="@font/geist_mono_bold"
                    android:singleLine="true"
                    tools:text="76,985"/>

                <LinearLayout
                    android:id="@+id/pill_sensex"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_gain_pill"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <ImageView
                        android:id="@+id/iv_sensex_trend"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginEnd="2dp"
                        android:src="@drawable/ic_trending_up"
                        android:contentDescription="trend"/>

                    <TextView
                        android:id="@+id/tv_sensex_change"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/gain_green"
                        android:textSize="11sp"
                        android:fontFamily="@font/geist_mono"
                        tools:text="+0.42%"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ── SECTION LABEL: US ─────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="UNITED STATES"
            android:textColor="@color/text_tertiary"
            android:textSize="10sp"
            android:fontFamily="@font/inter_semi_bold"
            android:letterSpacing="0.12"
            android:textAllCaps="true"/>

        <!-- ── US INDEX CARDS ─────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <!-- S&P 500 -->
            <LinearLayout
                android:id="@+id/card_sp500"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_index_card"
                android:padding="14dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S&amp;P 500"
                    android:textColor="@color/text_tertiary"
                    android:textSize="10sp"
                    android:fontFamily="@font/inter"
                    android:letterSpacing="0.05"/>

                <TextView
                    android:id="@+id/tv_sp500_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:fontFamily="@font/geist_mono_bold"
                    android:singleLine="true"
                    tools:text="5,667"/>

                <LinearLayout
                    android:id="@+id/pill_sp500"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_gain_pill"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <ImageView
                        android:id="@+id/iv_sp500_trend"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginEnd="2dp"
                        android:src="@drawable/ic_trending_up"
                        android:contentDescription="trend"/>

                    <TextView
                        android:id="@+id/tv_sp500_change"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/gain_green"
                        android:textSize="11sp"
                        android:fontFamily="@font/geist_mono"
                        tools:text="+0.22%"/>
                </LinearLayout>
            </LinearLayout>

            <!-- NASDAQ -->
            <LinearLayout
                android:id="@+id/card_nasdaq"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_index_card"
                android:padding="14dp"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NASDAQ"
                    android:textColor="@color/text_tertiary"
                    android:textSize="10sp"
                    android:fontFamily="@font/inter"
                    android:letterSpacing="0.05"/>

                <TextView
                    android:id="@+id/tv_nasdaq_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:fontFamily="@font/geist_mono_bold"
                    android:singleLine="true"
                    tools:text="17,754"/>

                <LinearLayout
                    android:id="@+id/pill_nasdaq"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_loss_pill"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <ImageView
                        android:id="@+id/iv_nasdaq_trend"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginEnd="2dp"
                        android:src="@drawable/ic_trending_down"
                        android:contentDescription="trend"/>

                    <TextView
                        android:id="@+id/tv_nasdaq_change"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/loss_red"
                        android:textSize="11sp"
                        android:fontFamily="@font/geist_mono"
                        tools:text="-0.18%"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ── DIVIDER ─────────────────────────────────── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="28dp"
            android:background="@color/divider_color"/>

        <!-- ── TOP MOVER SECTION ─────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOP MOVER TODAY"
                android:textColor="@color/text_tertiary"
                android:textSize="10sp"
                android:fontFamily="@font/inter_semi_bold"
                android:letterSpacing="0.12"
                android:textAllCaps="true"/>

            <!-- Top mover card (hidden when portfolio has no fetchable assets) -->
            <LinearLayout
                android:id="@+id/card_top_mover"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_index_card"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <!-- Left: symbol + name -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_top_mover_symbol"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:fontFamily="@font/inter_semi_bold"
                        android:textStyle="bold"
                        android:letterSpacing="-0.01"
                        tools:text="AAPL"/>

                    <TextView
                        android:id="@+id/tv_top_mover_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp"
                        android:fontFamily="@font/inter"
                        android:singleLine="true"
                        android:ellipsize="end"
                        tools:text="Apple Inc."/>
                </LinearLayout>

                <!-- Right: price + pill -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/tv_top_mover_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:fontFamily="@font/geist_mono_bold"
                        tools:text="$213.55"/>

                    <LinearLayout
                        android:id="@+id/pill_top_mover"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_gain_pill"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <ImageView
                            android:id="@+id/iv_top_mover_trend"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_marginEnd="2dp"
                            android:src="@drawable/ic_trending_up"
                            android:contentDescription="trend"/>

                        <TextView
                            android:id="@+id/tv_top_mover_change"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/gain_green"
                            android:textSize="11sp"
                            android:fontFamily="@font/geist_mono"
                            tools:text="+3.42%"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Empty state when portfolio has no fetchable assets -->
            <LinearLayout
                android:id="@+id/top_mover_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_index_card"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add investments to your portfolio to see today's top mover"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp"
                    android:fontFamily="@font/inter"/>
            </LinearLayout>

            <!-- Loading state -->
            <LinearLayout
                android:id="@+id/top_mover_loading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_index_card"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading market data…"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp"
                    android:fontFamily="@font/inter"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
