<?xml version="1.0" encoding="utf-8"?>
<appwidget-provider
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="250dp"
    android:minHeight="200dp"
    android:minResizeWidth="180dp"
    android:minResizeHeight="150dp"
    android:maxResizeWidth="500dp"
    android:maxResizeHeight="600dp"
    android:targetCellWidth="3"
    android:targetCellHeight="3"
    android:updatePeriodMillis="1800000"
    android:initialLayout="@layout/widget_stock_list"
    android:configure="com.saurabh.financewidget.ui.config.WidgetConfigActivity"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:widgetFeatures="reconfigurable"
    android:description="@string/widget_description"
    android:previewLayout="@layout/widget_stock_list"/>
